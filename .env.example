# Lever-Runner configuration
# Copy to .env and fill in real values. NEVER commit .env.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Optional: restrict bot to a single user (numeric Telegram user id)
ALLOWED_USER_ID=

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# --- LLM backend for intent extraction ---
# One of: passthrough | minimax | openai | deepinfra | ollama
# 'passthrough' uses the user request verbatim as the intent phrase (no LLM call).
# 'minimax' / 'openai' / 'deepinfra' call a hosted API. The key is read from
# the *process environment* (MINIMAX_API_KEY / ANTHROPIC_API_KEY /
# OPENAI_API_KEY / DEEPINFRA_API_KEY) so you do not need to put a key in
# this file. LLM_API_KEY (in this file or env) is the generic override.
LLM_BACKEND=minimax
LLM_BASE_URL=https://api.minimax.io/anthropic
LLM_MODEL=MiniMax-M3

# Provider fallback chain. Comma-separated backends tried in order when the
# primary errors with a retryable condition (timeout, 429, 5xx, 502, 503,
# 504, 529, or 401). 'passthrough' is always appended as the last resort.
# Set to empty string to disable fallbacks.
LLM_FALLBACKS=deepinfra
LLM_TIMEOUT_SEC=5

# Per-backend URL/model overrides (optional). Useful when a single provider
# has a different endpoint for inference vs. chat-completions, or when
# you want to pin one backend to a specific model without leaking the
# global LLM_BASE_URL into fallback attempts.
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/anthropic
# LLM_DEEPINAX_MODEL=Qwen/Qwen3-32B
LLM_DEEPINFRA_API_KEY=
# Or set DEEPINFRA_API_KEY in the process env. The key resolution order is
# LLM_API_KEY > DEEPINFRA_API_KEY > DEEPINFRA_KEY (first non-empty wins).

# --- Embedding model (local) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LanceDB ---
LANCEDB_PATH=./data/lever.lancedb
LANCEDB_TABLE=commands

# --- Sandbox ---
SANDBOX_ROOT=/tmp/lever-runner
COMMAND_TIMEOUT_SEC=30

# --- Self-improvement (optional) ---
# Used by auto_promote.py to rewrite failing commands. Leave blank to disable.
REMOTE_LLM_API_KEY=
REMOTE_LLM_MODEL=claude-3-5-sonnet-20241022
REMOTE_LLM_BASE_URL=https://api.anthropic.com

# --- Trust thresholds ---
TRUST_PROMOTE_FLOOR=30
TRUST_PROMOTE_FAILURES=5
TRUST_SUCCESS_BUMP_THRESHOLD=20
TRUST_SUCCESS_BUMP_AMOUNT=10
TRUST_NEW_COMMAND=50
TRUST_REWRITTEN_COMMAND=40
