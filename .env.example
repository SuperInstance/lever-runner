# Lever-Runner configuration
# Copy to .env and fill in real values. NEVER commit .env.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Optional: restrict bot to a single user (numeric Telegram user id)
ALLOWED_USER_ID=

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# --- LLM backend for intent extraction ---
# One of: passthrough | minimax | openai | ollama
# 'passthrough' uses the user request verbatim as the intent phrase (no LLM call).
# 'minimax' / 'openai' call a hosted API. The key is read from the *process
# environment* (MINIMAX_API_KEY / ANTHROPIC_API_KEY / OPENAI_API_KEY) so you
# do not need to put a key in this file.
LLM_BACKEND=passthrough
LLM_BASE_URL=https://api.minimax.io/anthropic
LLM_MODEL=MiniMax-M3

# --- Embedding model (local) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LanceDB ---
LANCEDB_PATH=./data/lever.lancedb
LANCEDB_TABLE=commands

# --- Sandbox ---
SANDBOX_ROOT=/tmp/lever-runner
COMMAND_TIMEOUT_SEC=30

# --- Self-improvement (optional) ---
# Used by auto_promote.py to rewrite failing commands. Leave blank to disable.
REMOTE_LLM_API_KEY=
REMOTE_LLM_MODEL=claude-3-5-sonnet-20241022
REMOTE_LLM_BASE_URL=https://api.anthropic.com

# --- Trust thresholds ---
TRUST_PROMOTE_FLOOR=30
TRUST_PROMOTE_FAILURES=5
TRUST_SUCCESS_BUMP_THRESHOLD=20
TRUST_SUCCESS_BUMP_AMOUNT=10
TRUST_NEW_COMMAND=50
TRUST_REWRITTEN_COMMAND=40
