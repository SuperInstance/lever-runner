{"intent_phrase": "list running pods",                    "command": "kubectl get pods"}
{"intent_phrase": "list pods in all namespaces",          "command": "kubectl get pods --all-namespaces"}
{"intent_phrase": "show pod details",                      "command": "kubectl describe pod"}
{"intent_phrase": "show pod logs",                         "command": "kubectl logs"}
{"intent_phrase": "tail pod logs following",               "command": "kubectl logs -f"}
{"intent_phrase": "list kubernetes services",              "command": "kubectl get services"}
{"intent_phrase": "list kubernetes deployments",           "command": "kubectl get deployments"}
{"intent_phrase": "show deployment status",               "command": "kubectl describe deployment"}
{"intent_phrase": "show kubernetes nodes",                 "command": "kubectl get nodes"}
{"intent_phrase": "show cluster info",                     "command": "kubectl cluster-info"}
{"intent_phrase": "show current kubectl context",          "command": "kubectl config current-context"}
{"intent_phrase": "list all kubectl contexts",             "command": "kubectl config get-contexts"}
{"intent_phrase": "switch kubectl context",                "command": "kubectl config use-context"}
{"intent_phrase": "apply a kubernetes manifest",           "command": "kubectl apply -f"}
{"intent_phrase": "delete a kubernetes resource",          "command": "kubectl delete -f"}
{"intent_phrase": "scale a deployment",                    "command": "kubectl scale deployment"}
{"intent_phrase": "rollback a deployment",                 "command": "kubectl rollout undo"}
{"intent_phrase": "show rollout status",                   "command": "kubectl rollout status"}
{"intent_phrase": "show rollout history",                  "command": "kubectl rollout history"}
{"intent_phrase": "exec into a pod",                       "command": "kubectl exec -it"}
{"intent_phrase": "port forward to a pod",                 "command": "kubectl port-forward"}
{"intent_phrase": "show kubernetes events",                "command": "kubectl get events --sort-by=.metadata.creationTimestamp"}
{"intent_phrase": "show resource usage of pods",           "command": "kubectl top pods"}
{"intent_phrase": "show resource usage of nodes",           "command": "kubectl top nodes"}
