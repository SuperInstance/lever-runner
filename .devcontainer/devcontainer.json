{
    "name": "lever-runner",
    "image": "mcr.microsoft.com/devcontainers/python:3.10",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "postCreateCommand": "pip install -e .",
    "forwardPorts": [8000],
    "customizations": {
        "codespaces": {
            "openFiles": ["README.md", "demo/demo.py"]
        }
    }
}
